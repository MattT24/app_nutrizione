</head>

<body>

    <!-- INTESTAZIONE NUTRIZIONISTA -->
    <div class="nutri-header" th:if="${nutrizionista != null}">
        <table>
            <tr>
                <td class="nutri-logo-cell" th:if="${logoBase64 != null}">
                    <img class="nutri-logo" th:src="${logoBase64}" alt="Logo" />
                </td>
                <td>
                    <div class="nutri-name" th:text="${'Dott. ' + (nutrizionista?.nome ?: '') + ' ' + (nutrizionista?.cognome ?: '')}">Dott. Nome Cognome</div>
                    <div class="nutri-info">
                        <span th:if="${nutrizionista?.email != null}" th:text="${nutrizionista.email}">email@example.com</span>
                        <span th:if="${nutrizionista?.telefono != null}"> &#160;|&#160; </span>
                        <span th:if="${nutrizionista?.telefono != null}" th:text="${nutrizionista.telefono}">333 1234567</span>
                        <br th:if="${nutrizionista?.indirizzo != null}" />
                        <span th:if="${nutrizionista?.indirizzo != null}" th:text="${nutrizionista.indirizzo}">Via Roma 1, Milano</span>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <!-- TITOLO SCHEDA -->
    <div class="doc-header">
        <table>
            <tr>
                <td>
                    <div class="doc-title" th:text="${scheda?.nome ?: 'Piano Alimentare Giornaliero'}">Piano Alimentare</div>
                </td>
                <td class="doc-date">
                    <div th:if="${scheda.dataCreazione != null}" th:text="${#temporals.format(scheda.dataCreazione, 'dd/MM/yyyy')}">26/03/2026</div>
                    <div th:text="'Giornaliero'">Tipo: GIORNALIERA</div>
                </td>
            </tr>
        </table>
    </div>

    <!-- INFO PAZIENTE -->
    <div class="patient-bar" th:if="${scheda.cliente != null}">
        <table>
            <tr>
                <td>
                    <span class="lbl">Paziente</span><br />
                    <span class="val" th:text="${(scheda.cliente?.nome ?: '') + ' ' + (scheda.cliente?.cognome ?: '')}">Mario Rossi</span>
                </td>
            </tr>
        </table>
    </div>

    <!-- PASTI GIORNALIERI -->
    <th:block th:each="pasto : ${pastiOrdinati}">
        <div th:replace="~{::pasto-content(pasto=${pasto})}"></div>
    </th:block>

    <!-- FRAGMENT PER IL CONTENUTO DEL PASTO -->
    <th:block th:fragment="pasto-content(pasto)">
        <div class="pasto" th:if="${pasto != null}">
            <div class="pasto-head">
                <table>
                    <tr>
                        <td>
                            <span class="pasto-name" th:text="${pasto?.nome ?: 'Pasto'}">Colazione</span>
                            <span class="giorno-label" th:if="${pasto?.giorno != null}" th:text="'(' + ${pasto.giorno} + ')'"></span>
                        </td>
                        <td class="pasto-time">
                            <span th:if="${pasto?.orarioInizio != null}" th:text="${#temporals.format(pasto.orarioInizio, 'HH:mm')}">08:00</span>
                            <span th:if="${pasto?.orarioInizio != null and pasto?.orarioFine != null}"> — </span>
                            <span th:if="${pasto?.orarioFine != null}" th:text="${#temporals.format(pasto.orarioFine, 'HH:mm')}">08:30</span>
                        </td>
                    </tr>
                </table>
            </div>

            <div class="pasto-desc" th:if="${pasto?.descrizione != null and !pasto.descrizione.isEmpty()}">
                <span th:text="${pasto.descrizione}">Descrizione del pasto</span>
            </div>

            <table class="food-table">
                <thead>
                    <tr>
                        <th>Alimento</th>
                        <th class="qty-col">Quantità</th>
                    </tr>
                </thead>
                <tbody>
                    <th:block th:each="ap : ${pasto.alimentiPasto}">
                        <tr>
                            <td>
                                <div class="food-name"
                                     th:text="${ap.nomeOverride != null ? ap.nomeOverride.nomeCustom : (ap.alimento != null ? ap.alimento.nome : 'N/D')}">
                                    Alimento
                                </div>
                                <div class="food-cat"
                                     th:if="${ap.alimento != null and ap.alimento.categoria != null}"
                                     th:text="${ap.alimento.categoria}">Categoria</div>
                            </td>
                            <td class="food-qty"
                                th:text="${ap.quantita > 0 ? ap.quantita + ' g' : 'A volontà'}">100 g</td>
                        </tr>
                        <!-- Alternative -->
                        <tr th:each="alt : ${ap.alternative}" class="alt-row">
                            <td>
                                <div class="alt-name">
                                    <span class="alt-prefix">Oppure:</span> 
                                    <span th:text="${alt.nomeCustom != null ? alt.nomeCustom : (alt.alimentoAlternativo != null ? alt.alimentoAlternativo.nome : 'N/D')}">Alimento</span>
                                    <span th:if="${alt.note != null and !alt.note.empty}" th:text="' (' + ${alt.note} + ')'"> (note)</span>
                                </div>
                            </td>
                            <td class="food-qty" th:text="${alt.quantita > 0 ? alt.quantita + ' g' : 'A volontà'}">100 g</td>
                        </tr>
                    </th:block>
                </tbody>
            </table>
        </div>
    </th:block>

    <!-- FOOTER -->
    <div class="doc-footer">
        <p>Documento riservato al destinatario — generato digitalmente da Statera Nutrition</p>
        <p>Consultare il professionista prima di modificare il piano</p>
    </div>

</body>
</html>
