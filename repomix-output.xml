            </tr>
            <tr th:if="${misurazione.fianchi != null}">
                <td class="data-label">Fianchi</td>
                <td class="data-value"><span th:text="${misurazione.fianchi}"></span><span class="unit">cm</span></td>
            </tr>
            <tr th:if="${misurazione.torace != null}">
                <td class="data-label">Torace</td>
                <td class="data-value"><span th:text="${misurazione.torace}"></span><span class="unit">cm</span></td>
            </tr>
            <tr th:if="${misurazione.gambaS != null}">
                <td class="data-label">Gamba Sinistra</td>
                <td class="data-value"><span th:text="${misurazione.gambaS}"></span><span class="unit">cm</span></td>
            </tr>
            <tr th:if="${misurazione.gambaD != null}">
                <td class="data-label">Gamba Destra</td>
                <td class="data-value"><span th:text="${misurazione.gambaD}"></span><span class="unit">cm</span></td>
            </tr>
            <tr th:if="${misurazione.bicipiteS != null}">
                <td class="data-label">Bicipite Sinistro</td>
                <td class="data-value"><span th:text="${misurazione.bicipiteS}"></span><span class="unit">cm</span></td>
            </tr>
            <tr th:if="${misurazione.bicipiteD != null}">
                <td class="data-label">Bicipite Destro</td>
                <td class="data-value"><span th:text="${misurazione.bicipiteD}"></span><span class="unit">cm</span></td>
            </tr>
        </tbody>
    </table>

    <!-- FOOTER -->
    <div class="doc-footer">
        <p>Documento riservato al destinatario — generato digitalmente da Statera Nutrition</p>
        <p>Consultare il professionista per l'interpretazione dei dati</p>
    </div>

</body>

</html>
