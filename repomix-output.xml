                </td>
            </tr>
        </table>
    </div>

    <!-- INFO PAZIENTE -->
    <div class="patient-bar" th:if="${plicometria.cliente != null}">
        <table>
            <tr>
                <td>
                    <span class="lbl">Paziente</span><br />
                    <span class="val" th:text="${plicometria.cliente.nome + ' ' + plicometria.cliente.cognome}">Mario Rossi</span>
                </td>
            </tr>
        </table>
    </div>

    <!-- TABELLA PLICHE -->
    <table class="data-table">
        <thead>
            <tr>
                <th>Plica</th>
                <th style="text-align: right;">Misurazione</th>
            </tr>
        </thead>
        <tbody>
            <tr th:if="${plicometria.tricipite != null}">
                <td class="data-label">Tricipite</td>
                <td class="data-value"><span th:text="${plicometria.tricipite}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.bicipite != null}">
                <td class="data-label">Bicipite</td>
                <td class="data-value"><span th:text="${plicometria.bicipite}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.sottoscapolare != null}">
                <td class="data-label">Sottoscapolare</td>
                <td class="data-value"><span th:text="${plicometria.sottoscapolare}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.sovrailiaca != null}">
                <td class="data-label">Sovrailiaca</td>
                <td class="data-value"><span th:text="${plicometria.sovrailiaca}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.addominale != null}">
                <td class="data-label">Addominale</td>
                <td class="data-value"><span th:text="${plicometria.addominale}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.coscia != null}">
                <td class="data-label">Coscia</td>
                <td class="data-value"><span th:text="${plicometria.coscia}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.pettorale != null}">
                <td class="data-label">Pettorale</td>
                <td class="data-value"><span th:text="${plicometria.pettorale}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.ascellare != null}">
                <td class="data-label">Ascellare</td>
                <td class="data-value"><span th:text="${plicometria.ascellare}"></span><span class="unit">mm</span></td>
            </tr>
            <tr th:if="${plicometria.polpaccio != null}">
                <td class="data-label">Polpaccio</td>
                <td class="data-value"><span th:text="${plicometria.polpaccio}"></span><span class="unit">mm</span></td>
            </tr>
        </tbody>
    </table>

    <!-- RISULTATI CALCOLATI -->
    <div class="results-box">
        <div class="results-title">Risultati Elaborati</div>
        <table style="width: 100%;">
            <tr>
                <td style="width: 33%; border: none;">
                    <div class="result-lbl">Massa Grassa (%)</div>
                    <div class="result-val" th:text="${plicometria.percentualeMassaGrassa != null ? T(java.lang.String).format('%.2f', plicometria.percentualeMassaGrassa) + '%' : '-'}">-</div>
                </td>
                <td style="width: 33%; border: none;">
                    <div class="result-lbl">Massa Grassa (kg)</div>
                    <div class="result-val" th:text="${plicometria.massaGrassaKg != null ? T(java.lang.String).format('%.2f', plicometria.massaGrassaKg) + ' kg' : '-'}">-</div>
                </td>
                <td style="width: 33%; border: none;">
                    <div class="result-lbl">Massa Magra (kg)</div>
                    <div class="result-val" th:text="${plicometria.massaMagraKg != null ? T(java.lang.String).format('%.2f', plicometria.massaMagraKg) + ' kg' : '-'}">-</div>
                </td>
            </tr>
        </table>
    </div>

    <!-- NOTE -->
    <div class="note-box" th:if="${plicometria.note != null && !plicometria.note.isEmpty()}">
        <strong>Note:</strong> <span th:text="${plicometria.note}"></span>
    </div>

    <!-- FOOTER -->
    <div class="doc-footer">
        <p>Documento riservato al destinatario — generato digitalmente da Statera Nutrition</p>
        <p>I calcoli sono stime basate su modelli antropometrici standard</p>
    </div>

</body>

</html>
