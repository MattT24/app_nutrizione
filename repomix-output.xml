<body>
<div class="container">

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <h1>Piano Alimentare Personalizzato</h1>
            <p class="subtitle">Elaborato da Studio Statera · Nutrizione Clinica</p>
        </div>
        <div class="header-right">
            <div class="header-badge">Documento Riservato</div>
        </div>
    </div>

    <!-- PATIENT INFO + GOALS -->
    <div class="info-row-wrap">
        <div class="info-col">
            <div class="card">
                <h2>Informazioni Paziente</h2>
                <table class="info-table">
                    <tr>
                        <td class="lbl">Nome</td>
                        <td class="val" th:text="${paziente.nome + ' ' + paziente.cognome}"></td>
                    </tr>
                    <tr>
                        <td class="lbl">Data di Nascita</td>
                        <td class="val" th:text="${#temporals.format(paziente.dataNascita, 'dd/MM/yyyy')}"></td>
                    </tr>
                    <tr>
                        <td class="lbl">Codice Fiscale</td>
                        <td class="val" th:text="${paziente.codiceFiscale}"></td>
                    </tr>
                    <tr>
                        <td class="lbl">Email</td>
                        <td class="val" th:text="${paziente.email}"></td>
                    </tr>
                    <tr>
                        <td class="lbl">Telefono</td>
                        <td class="val" th:text="${paziente.telefono}"></td>
                    </tr>
                    <tr>
                        <td class="lbl">Data Piano</td>
                        <td class="val" th:text="${dataCreazione}"></td>
                    </tr>
                    <tr th:if="${dataInizio != null and dataFine != null}">
                        <td class="lbl">Validità</td>
                        <td class="val" th:text="${dataInizio + ' → ' + dataFine}"></td>
                    </tr>
                </table>
            </div>
        </div>
        <div class="info-col">
            <div class="card card-green">
                <h2>Obiettivi Nutrizionali</h2>
                <p style="font-size:9pt; color:#166534; margin: 0 0 10px 0;" th:text="${piano.obiettivo}"></p>
                <div class="kcal-box">
                    <span th:text="${piano.calorieGiornaliere}"></span> <span>kcal / giorno</span>
                </div>
            </div>
            <div class="card card-amber" th:if="${piano.note != null and !piano.note.isEmpty()}">
                <h2>Note e Raccomandazioni</h2>
                <p style="font-size:9pt; color:#78350f; margin:0;" th:text="${piano.note}"></p>
            </div>
        </div>
    </div>

    <!-- DAYS -->
    <div th:each="giorno, iterStat : ${giorni}" class="day-section">

        <div class="day-header">
            <div class="day-header-left" th:text="${giorno.nomeGiorno}"></div>
            <div class="day-header-right" th:text="'Giorno ' + ${giorno.numeroGiorno}"></div>
        </div>

        <table class="meals-table">
            <thead>
                <tr>
                    <th style="width:18%">Pasto</th>
                    <th style="width:9%">Orario</th>
                    <th style="width:45%">Alimenti</th>
                    <th style="width:28%">Macronutrienti</th>
                </tr>
            </thead>
            <tbody>
                <tr th:each="pasto : ${giorno.pasti}">
                    <td>
                        <div class="meal-name" th:text="${pasto.tipoPasto}"></div>
                    </td>
                    <td style="color:#64748b; font-size:8.5pt;" th:text="${pasto.orario}"></td>
                    <td>
                        <div class="meal-desc" th:text="${pasto.descrizione}"></div>
                    </td>
                    <td>
                        <div class="macros-wrap">
                            <span class="macro-badge mb-kcal" th:text="${pasto.calorie + ' kcal'}"></span>
                            <span class="macro-badge mb-p" th:text="'P ' + ${#numbers.formatDecimal(pasto.proteine,1,1)} + 'g'"></span>
                            <span class="macro-badge mb-c" th:text="'C ' + ${#numbers.formatDecimal(pasto.carboidrati,1,1)} + 'g'"></span>
                            <span class="macro-badge mb-g" th:text="'G ' + ${#numbers.formatDecimal(pasto.grassi,1,1)} + 'g'"></span>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="day-summary">
            <table class="summary-table">
                <tr>
                    <td>
                        <span class="summary-lbl">Calorie</span>
                        <span class="summary-val kcal-val" th:text="${giorno.getTotaleCalorie()}"></span>
                        <span class="summary-unit">kcal</span>
                    </td>
                    <td>
                        <span class="summary-lbl">Proteine</span>
                        <span class="summary-val" th:text="${#numbers.formatDecimal(giorno.getTotaleProteine(),1,1)}"></span>
                        <span class="summary-unit">g</span>
                    </td>
                    <td>
                        <span class="summary-lbl">Carboidrati</span>
                        <span class="summary-val" th:text="${#numbers.formatDecimal(giorno.getTotaleCarboidrati(),1,1)}"></span>
                        <span class="summary-unit">g</span>
                    </td>
                    <td>
                        <span class="summary-lbl">Grassi</span>
                        <span class="summary-val" th:text="${#numbers.formatDecimal(giorno.getTotaleGrassi(),1,1)}"></span>
                        <span class="summary-unit">g</span>
                    </td>
                </tr>
            </table>
        </div>

        <div th:if="${iterStat.index % 2 == 1 and !iterStat.last}" class="page-break"></div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <strong>Studio Statera — Nutrizione Clinica</strong><br/>
        Questo documento è strettamente personale e riservato al paziente indicato. Non riprodurre senza autorizzazione.
    </div>

</div>
</body>
</html>
</file>

