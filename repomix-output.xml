    @Query("SELECT r FROM Ricetta r WHERE r.pubblica = true AND LOWER(r.titolo) LIKE LOWER(CONCAT('%', :query, '%')) ORDER BY r.titolo ASC")
    List<Ricetta> searchByTitolo(@Param("query") String query);

