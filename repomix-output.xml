    @Query("SELECT DISTINCT r FROM Ricetta r LEFT JOIN FETCH r.ingredienti ing LEFT JOIN FETCH ing.alimento WHERE r.pubblica = true ORDER BY r.titolo ASC")
    List<Ricetta> findAllPublicWithIngredienti();
}
