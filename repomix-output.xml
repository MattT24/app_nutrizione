            display: table;
            width: 100%;
            margin-bottom: 16px;
            border-spacing: 12px 0;
        }

        .info-col {
            display: table-cell;
            vertical-align: top;
            width: 50%;
        }

        /* ── SECTION CARD ── */
        .card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 14px 16px;
            margin-bottom: 14px;
        }

        .card-green {
            background: #f0fdf4;
            border-color: #bbf7d0;
            border-left: 4px solid #10b981;
        }

        .card-amber {
            background: #fffbeb;
            border-color: #fde68a;
            border-left: 4px solid #f59e0b;
        }

        .card h2 {
            font-size: 9pt;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #10b981;
